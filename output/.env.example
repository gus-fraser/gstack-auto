# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Auth
ADMIN_SECRET=change-me-to-a-strong-secret

# OpenAI (for embeddings + chat completion)
OPENAI_API_KEY=sk-...

# Resend (magic link emails)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Vercel Blob (document storage)
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# White-label
FUND_NAME=Hudson Capital
FUND_LOGO_URL=/placeholder-logo.svg
FUND_ACCENT_COLOR=#3b82f6

# App URL (for magic links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
